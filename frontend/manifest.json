{
  "manifest_version": 3,
  "name": "Inbox Intelligence",
  "version": "1.0.0",
  "description": "AI-powered email intelligence extension",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "alarms"],
  "host_permissions": ["http://localhost:5000/*"]
}

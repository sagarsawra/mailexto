{
  "manifest_version": 3,
  "name": "Inbox Intelligence",
  "version": "1.0.0",
  "description": "AI-powered email intelligence extension",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "alarms"],
  "host_permissions": ["http://localhost:8000/*", "https://your-backend.com/*"]
}
